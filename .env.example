# ================================================
# POWIP FRONTEND — Variables de entorno requeridas
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env con valores reales
# ================================================

# ================================
# API — Microservicios (producción)
# ================================
NEXT_PUBLIC_API_GATEWAY=

# ================================
# URLs públicas
# ================================
NEXT_PUBLIC_FRONTEND_URL=
NEXT_PUBLIC_LANDING_URL=

# ================================
# Supabase
# ================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service role key: solo server-side, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# ================================
# Mercado Pago
# ================================
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# ================================
# Google
# ================================
# API Key restringida por HTTP referrer (GCP Console)
NEXT_PUBLIC_GOOGLE_API_KEY=

# ================================
# Seguridad — Webhooks
# ================================
# Shared secret para el webhook de Google Forms/Apps Script
WEBHOOK_SECRET_GOOGLE_FORMS=

# ================================
# Superadmin — Control de acceso
# ================================
# Lista de emails con acceso superadmin, separados por coma
# Ejemplo: admin@empresa.com,otro@empresa.com
SUPERADMIN_EMAILS=
